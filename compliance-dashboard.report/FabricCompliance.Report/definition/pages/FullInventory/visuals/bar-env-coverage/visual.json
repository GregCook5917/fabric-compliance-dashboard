{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/1.0.0/schema.json",
  "name": "bar-env-coverage",
  "position": {
    "x": 880,
    "y": 215,
    "z": 0,
    "width": 380,
    "height": 300,
    "tabOrder": 400
  },
  "visual": {
    "visualType": "clusteredBarChart",
    "query": {
      "queryState": {
        "Category": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "inventory"
                    }
                  },
                  "Property": "triplet_name"
                }
              }
            }
          ]
        },
        "Y": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "Measures"
                    }
                  },
                  "Property": "Test Coverage Pct"
                }
              }
            },
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "Measures"
                    }
                  },
                  "Property": "Prod Coverage Pct"
                }
              }
            }
          ]
        }
      }
    },
    "title": {
      "show": true,
      "text": "Environment Coverage by Triplet (% of Dev)"
    },
    "objects": {
      "legend": [
        {
          "properties": {
            "show": true,
            "position": "Top",
            "fontSize": 10
          }
        }
      ],
      "valueAxis": [
        {
          "properties": {
            "start": 0,
            "end": 100
          }
        }
      ]
    }
  }
}