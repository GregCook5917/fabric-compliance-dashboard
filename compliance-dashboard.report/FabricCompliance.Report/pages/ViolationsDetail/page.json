{
  "name": "ViolationsDetail",
  "displayName": "Violations Detail",
  "ordinal": 1,
  "width": 1280,
  "height": 720,
  "background": {
    "color": { "solid": { "color": "#F4F3EE" } },
    "transparency": 0
  },
  "visualContainers": [

    {
      "id": "header-bar",
      "x": 0, "y": 0, "width": 1280, "height": 50,
      "visual": {
        "visualType": "shape",
        "objects": {
          "general": [{ "properties": { "fill": { "solid": { "color": "#1A1A2E" } } } }],
          "border": [{ "properties": { "show": { "expr": { "Literal": { "Value": "false" } } } } }]
        }
      }
    },

    {
      "id": "header-title",
      "x": 20, "y": 8, "width": 500, "height": 34,
      "visual": {
        "visualType": "textbox",
        "objects": {
          "general": [{
            "properties": {
              "paragraphs": [{
                "textRuns": [{
                  "value": "Fabric Deployment Compliance  —  Violations Detail",
                  "textStyle": { "fontFamily": "Segoe UI", "fontSize": "14pt", "bold": true, "color": "#FFFFFF" }
                }]
              }]
            }
          }]
        }
      }
    },

    {
      "id": "slicer-violation-type",
      "x": 20, "y": 60, "width": 220, "height": 200,
      "visual": {
        "visualType": "slicer",
        "projections": {
          "Values": [{ "queryRef": "violations.violation_type", "active": true }]
        },
        "prototypeQuery": {
          "Version": 2,
          "From": [{ "Name": "v", "Entity": "violations", "Type": 0 }],
          "Select": [{ "Column": { "Expression": { "SourceRef": { "Source": "v" } }, "Property": "violation_type" }, "Name": "violations.violation_type" }]
        },
        "objects": {
          "general": [{ "properties": { "orientation": { "expr": { "Literal": { "Value": "'Vertical'" } } } } }],
          "selection": [{ "properties": { "selectAllCheckboxEnabled": { "expr": { "Literal": { "Value": "true" } } }, "singleSelect": { "expr": { "Literal": { "Value": "false" } } } } }],
          "header": [{ "properties": {
            "show": { "expr": { "Literal": { "Value": "true" } } },
            "text": { "expr": { "Literal": { "Value": "'Violation Type'" } } },
            "fontColor": { "solid": { "color": "#888780" } },
            "fontSize": { "expr": { "Literal": { "Value": "10D" } } }
          }}],
          "items": [{ "properties": {
            "fontSize": { "expr": { "Literal": { "Value": "11D" } } },
            "fontColor": { "solid": { "color": "#1A1A2E" } }
          }}]
        }
      }
    },

    {
      "id": "slicer-object-type",
      "x": 20, "y": 275, "width": 220, "height": 190,
      "visual": {
        "visualType": "slicer",
        "projections": {
          "Values": [{ "queryRef": "violations.object_type", "active": true }]
        },
        "prototypeQuery": {
          "Version": 2,
          "From": [{ "Name": "v", "Entity": "violations", "Type": 0 }],
          "Select": [{ "Column": { "Expression": { "SourceRef": { "Source": "v" } }, "Property": "object_type" }, "Name": "violations.object_type" }]
        },
        "objects": {
          "general": [{ "properties": { "orientation": { "expr": { "Literal": { "Value": "'Vertical'" } } } } }],
          "selection": [{ "properties": { "selectAllCheckboxEnabled": { "expr": { "Literal": { "Value": "true" } } }, "singleSelect": { "expr": { "Literal": { "Value": "false" } } } } }],
          "header": [{ "properties": {
            "show": { "expr": { "Literal": { "Value": "true" } } },
            "text": { "expr": { "Literal": { "Value": "'Object Type'" } } },
            "fontColor": { "solid": { "color": "#888780" } },
            "fontSize": { "expr": { "Literal": { "Value": "10D" } } }
          }}],
          "items": [{ "properties": {
            "fontSize": { "expr": { "Literal": { "Value": "11D" } } }
          }}]
        }
      }
    },

    {
      "id": "slicer-triplet",
      "x": 20, "y": 478, "width": 220, "height": 220,
      "visual": {
        "visualType": "slicer",
        "projections": {
          "Values": [{ "queryRef": "violations.triplet_name", "active": true }]
        },
        "prototypeQuery": {
          "Version": 2,
          "From": [{ "Name": "v", "Entity": "violations", "Type": 0 }],
          "Select": [{ "Column": { "Expression": { "SourceRef": { "Source": "v" } }, "Property": "triplet_name" }, "Name": "violations.triplet_name" }]
        },
        "objects": {
          "general": [{ "properties": { "orientation": { "expr": { "Literal": { "Value": "'Vertical'" } } } } }],
          "selection": [{ "properties": { "selectAllCheckboxEnabled": { "expr": { "Literal": { "Value": "true" } } }, "singleSelect": { "expr": { "Literal": { "Value": "false" } } } } }],
          "header": [{ "properties": {
            "show": { "expr": { "Literal": { "Value": "true" } } },
            "text": { "expr": { "Literal": { "Value": "'Triplet'" } } },
            "fontColor": { "solid": { "color": "#888780" } },
            "fontSize": { "expr": { "Literal": { "Value": "10D" } } }
          }}],
          "items": [{ "properties": {
            "fontSize": { "expr": { "Literal": { "Value": "11D" } } }
          }}]
        }
      }
    },

    {
      "id": "slicer-workspace",
      "x": 260, "y": 60, "width": 1000, "height": 50,
      "visual": {
        "visualType": "slicer",
        "projections": {
          "Values": [{ "queryRef": "violations.workspace", "active": true }]
        },
        "prototypeQuery": {
          "Version": 2,
          "From": [{ "Name": "v", "Entity": "violations", "Type": 0 }],
          "Select": [{ "Column": { "Expression": { "SourceRef": { "Source": "v" } }, "Property": "workspace" }, "Name": "violations.workspace" }]
        },
        "objects": {
          "general": [{ "properties": { "orientation": { "expr": { "Literal": { "Value": "'Horizontal'" } } } } }],
          "selection": [{ "properties": { "selectAllCheckboxEnabled": { "expr": { "Literal": { "Value": "true" } } }, "singleSelect": { "expr": { "Literal": { "Value": "false" } } } } }],
          "header": [{ "properties": {
            "show": { "expr": { "Literal": { "Value": "true" } } },
            "text": { "expr": { "Literal": { "Value": "'Workspace'" } } },
            "fontColor": { "solid": { "color": "#888780" } },
            "fontSize": { "expr": { "Literal": { "Value": "10D" } } }
          }}]
        }
      }
    },

    {
      "id": "table-violations",
      "x": 260, "y": 120, "width": 1000, "height": 580,
      "visual": {
        "visualType": "tableEx",
        "projections": {
          "Values": [
            { "queryRef": "violations.triplet_name", "active": true },
            { "queryRef": "violations.workspace", "active": true },
            { "queryRef": "violations.object_name", "active": true },
            { "queryRef": "violations.object_type", "active": true },
            { "queryRef": "violations.violation_type", "active": true },
            { "queryRef": "Measures.Exists In Dev", "active": true },
            { "queryRef": "Measures.Exists In Git", "active": true },
            { "queryRef": "violations.sync_state", "active": true }
          ]
        },
        "prototypeQuery": {
          "Version": 2,
          "From": [
            { "Name": "v", "Entity": "violations", "Type": 0 },
            { "Name": "m", "Entity": "Measures", "Type": 0 }
          ],
          "Select": [
            { "Column": { "Expression": { "SourceRef": { "Source": "v" } }, "Property": "triplet_name" }, "Name": "violations.triplet_name" },
            { "Column": { "Expression": { "SourceRef": { "Source": "v" } }, "Property": "workspace" }, "Name": "violations.workspace" },
            { "Column": { "Expression": { "SourceRef": { "Source": "v" } }, "Property": "object_name" }, "Name": "violations.object_name" },
            { "Column": { "Expression": { "SourceRef": { "Source": "v" } }, "Property": "object_type" }, "Name": "violations.object_type" },
            { "Column": { "Expression": { "SourceRef": { "Source": "v" } }, "Property": "violation_type" }, "Name": "violations.violation_type" },
            { "Measure": { "Expression": { "SourceRef": { "Source": "m" } }, "Property": "Exists In Dev" }, "Name": "Measures.Exists In Dev" },
            { "Measure": { "Expression": { "SourceRef": { "Source": "m" } }, "Property": "Exists In Git" }, "Name": "Measures.Exists In Git" },
            { "Column": { "Expression": { "SourceRef": { "Source": "v" } }, "Property": "sync_state" }, "Name": "violations.sync_state" }
          ],
          "OrderBy": [
            { "Direction": 1, "Expression": { "Column": { "Expression": { "SourceRef": { "Source": "v" } }, "Property": "triplet_name" } } }
          ]
        },
        "drillthrough": {
          "enabled": true,
          "target": "FullInventory"
        },
        "objects": {
          "title": [{ "properties": {
            "show": { "expr": { "Literal": { "Value": "true" } } },
            "text": { "expr": { "Literal": { "Value": "'Violation Records — click any row to drill through to full inventory'" } } },
            "fontSize": { "expr": { "Literal": { "Value": "11D" } } },
            "fontColor": { "solid": { "color": "#888780" } }
          }}],
          "grid": [{ "properties": {
            "rowPadding": { "expr": { "Literal": { "Value": "8D" } } },
            "gridHorizontalColor": { "solid": { "color": "#E0DFD8" } },
            "outlineColor": { "solid": { "color": "#E0DFD8" } }
          }}],
          "columnHeaders": [{ "properties": {
            "fontColor": { "solid": { "color": "#888780" } },
            "fontSize": { "expr": { "Literal": { "Value": "10D" } } },
            "backColor": { "solid": { "color": "#F4F3EE" } },
            "bold": { "expr": { "Literal": { "Value": "false" } } }
          }}],
          "values": [{ "properties": {
            "fontColorPrimary": { "solid": { "color": "#1A1A2E" } },
            "backColorPrimary": { "solid": { "color": "#FFFFFF" } },
            "backColorSecondary": { "solid": { "color": "#F9F8F5" } },
            "fontSize": { "expr": { "Literal": { "Value": "11D" } } }
          }}]
        },
        "conditionalFormatting": [
          {
            "visualField": "violations.violation_type",
            "type": "background",
            "rules": [
              { "operator": "Is", "value": "UNSYNCED", "color": { "solid": { "color": "#FCEBEB" } } },
              { "operator": "Is", "value": "ORPHANED_OBJECT", "color": { "solid": { "color": "#FAEEDA" } } },
              { "operator": "Is", "value": "UNCOMMITTED_PROMOTION", "color": { "solid": { "color": "#EEEDFE" } } }
            ]
          },
          {
            "visualField": "violations.violation_type",
            "type": "fontColor",
            "rules": [
              { "operator": "Is", "value": "UNSYNCED", "color": { "solid": { "color": "#A32D2D" } } },
              { "operator": "Is", "value": "ORPHANED_OBJECT", "color": { "solid": { "color": "#854F0B" } } },
              { "operator": "Is", "value": "UNCOMMITTED_PROMOTION", "color": { "solid": { "color": "#3C3489" } } }
            ]
          },
          {
            "visualField": "violations.workspace",
            "type": "background",
            "rules": [
              { "operator": "Is", "value": "Dev", "color": { "solid": { "color": "#E6F1FB" } } },
              { "operator": "Is", "value": "Test", "color": { "solid": { "color": "#FAEEDA" } } },
              { "operator": "Is", "value": "Prod", "color": { "solid": { "color": "#FCEBEB" } } }
            ]
          },
          {
            "visualField": "violations.sync_state",
            "type": "fontColor",
            "rules": [
              { "operator": "Is", "value": "Synced", "color": { "solid": { "color": "#0F6E56" } } },
              { "operator": "Is", "value": "Unsynced", "color": { "solid": { "color": "#A32D2D" } } }
            ]
          }
        ]
      }
    }

  ]
}
