{
  "name": "FullInventory",
  "displayName": "Full Inventory",
  "ordinal": 2,
  "width": 1280,
  "height": 720,
  "background": {
    "color": { "solid": { "color": "#F4F3EE" } },
    "transparency": 0
  },
  "drillthrough": {
    "enabled": true,
    "keepAllFilters": true,
    "fields": [
      { "queryRef": "violations.object_name" },
      { "queryRef": "violations.triplet_name" }
    ]
  },
  "visualContainers": [

    {
      "id": "header-bar",
      "x": 0, "y": 0, "width": 1280, "height": 50,
      "visual": {
        "visualType": "shape",
        "objects": {
          "general": [{ "properties": { "fill": { "solid": { "color": "#1A1A2E" } } } }],
          "border": [{ "properties": { "show": { "expr": { "Literal": { "Value": "false" } } } } }]
        }
      }
    },

    {
      "id": "header-title",
      "x": 20, "y": 8, "width": 600, "height": 34,
      "visual": {
        "visualType": "textbox",
        "objects": {
          "general": [{
            "properties": {
              "paragraphs": [{
                "textRuns": [{
                  "value": "Fabric Deployment Compliance  —  Full Inventory Audit",
                  "textStyle": { "fontFamily": "Segoe UI", "fontSize": "14pt", "bold": true, "color": "#FFFFFF" }
                }]
              }]
            }
          }]
        }
      }
    },

    {
      "id": "kpi-total-objects",
      "x": 20, "y": 60, "width": 225, "height": 80,
      "visual": {
        "visualType": "card",
        "projections": {
          "Values": [{ "queryRef": "Measures.Total Objects", "active": true }]
        },
        "prototypeQuery": {
          "Version": 2,
          "From": [{ "Name": "m", "Entity": "Measures", "Type": 0 }],
          "Select": [{ "Measure": { "Expression": { "SourceRef": { "Source": "m" } }, "Property": "Total Objects" }, "Name": "Measures.Total Objects" }]
        },
        "objects": {
          "labels": [{ "properties": { "fontSize": { "expr": { "Literal": { "Value": "24D" } } }, "color": { "solid": { "color": "#1A1A2E" } } } }],
          "title": [{ "properties": { "show": { "expr": { "Literal": { "Value": "true" } } }, "text": { "expr": { "Literal": { "Value": "'Total Objects'" } } }, "fontColor": { "solid": { "color": "#888780" } }, "fontSize": { "expr": { "Literal": { "Value": "10D" } } } } }]
        }
      }
    },

    {
      "id": "kpi-in-dev",
      "x": 265, "y": 60, "width": 225, "height": 80,
      "visual": {
        "visualType": "card",
        "projections": {
          "Values": [{ "queryRef": "Measures.Objects In Dev", "active": true }]
        },
        "prototypeQuery": {
          "Version": 2,
          "From": [{ "Name": "m", "Entity": "Measures", "Type": 0 }],
          "Select": [{ "Measure": { "Expression": { "SourceRef": { "Source": "m" } }, "Property": "Objects In Dev" }, "Name": "Measures.Objects In Dev" }]
        },
        "objects": {
          "labels": [{ "properties": { "fontSize": { "expr": { "Literal": { "Value": "24D" } } }, "color": { "solid": { "color": "#1A1A2E" } } } }],
          "title": [{ "properties": { "show": { "expr": { "Literal": { "Value": "true" } } }, "text": { "expr": { "Literal": { "Value": "'In Dev'" } } }, "fontColor": { "solid": { "color": "#888780" } }, "fontSize": { "expr": { "Literal": { "Value": "10D" } } } } }]
        }
      }
    },

    {
      "id": "kpi-git-backed",
      "x": 510, "y": 60, "width": 225, "height": 80,
      "visual": {
        "visualType": "card",
        "projections": {
          "Values": [{ "queryRef": "Measures.Git Backed Count", "active": true }]
        },
        "prototypeQuery": {
          "Version": 2,
          "From": [{ "Name": "m", "Entity": "Measures", "Type": 0 }],
          "Select": [{ "Measure": { "Expression": { "SourceRef": { "Source": "m" } }, "Property": "Git Backed Count" }, "Name": "Measures.Git Backed Count" }]
        },
        "objects": {
          "labels": [{ "properties": { "fontSize": { "expr": { "Literal": { "Value": "24D" } } }, "color": { "solid": { "color": "#1A1A2E" } } } }],
          "title": [{ "properties": { "show": { "expr": { "Literal": { "Value": "true" } } }, "text": { "expr": { "Literal": { "Value": "'Git-Backed'" } } }, "fontColor": { "solid": { "color": "#888780" } }, "fontSize": { "expr": { "Literal": { "Value": "10D" } } } } }]
        }
      }
    },

    {
      "id": "kpi-fully-synced",
      "x": 755, "y": 60, "width": 225, "height": 80,
      "visual": {
        "visualType": "card",
        "projections": {
          "Values": [{ "queryRef": "Measures.Fully Synced Count", "active": true }]
        },
        "prototypeQuery": {
          "Version": 2,
          "From": [{ "Name": "m", "Entity": "Measures", "Type": 0 }],
          "Select": [{ "Measure": { "Expression": { "SourceRef": { "Source": "m" } }, "Property": "Fully Synced Count" }, "Name": "Measures.Fully Synced Count" }]
        },
        "objects": {
          "labels": [{ "properties": { "fontSize": { "expr": { "Literal": { "Value": "24D" } } }, "color": { "solid": { "color": "#0F6E56" } } } }],
          "title": [{ "properties": { "show": { "expr": { "Literal": { "Value": "true" } } }, "text": { "expr": { "Literal": { "Value": "'Fully Synced'" } } }, "fontColor": { "solid": { "color": "#888780" } }, "fontSize": { "expr": { "Literal": { "Value": "10D" } } } } }]
        }
      }
    },

    {
      "id": "kpi-with-violations",
      "x": 1000, "y": 60, "width": 260, "height": 80,
      "visual": {
        "visualType": "card",
        "projections": {
          "Values": [{ "queryRef": "Measures.Total Violations", "active": true }]
        },
        "prototypeQuery": {
          "Version": 2,
          "From": [{ "Name": "m", "Entity": "Measures", "Type": 0 }],
          "Select": [{ "Measure": { "Expression": { "SourceRef": { "Source": "m" } }, "Property": "Total Violations" }, "Name": "Measures.Total Violations" }]
        },
        "objects": {
          "labels": [{ "properties": { "fontSize": { "expr": { "Literal": { "Value": "24D" } } }, "color": { "solid": { "color": "#A32D2D" } } } }],
          "title": [{ "properties": { "show": { "expr": { "Literal": { "Value": "true" } } }, "text": { "expr": { "Literal": { "Value": "'With Violations'" } } }, "fontColor": { "solid": { "color": "#888780" } }, "fontSize": { "expr": { "Literal": { "Value": "10D" } } } } }]
        }
      }
    },

    {
      "id": "slicer-triplet",
      "x": 20, "y": 155, "width": 200, "height": 50,
      "visual": {
        "visualType": "slicer",
        "projections": {
          "Values": [{ "queryRef": "inventory.triplet_name", "active": true }]
        },
        "prototypeQuery": {
          "Version": 2,
          "From": [{ "Name": "i", "Entity": "inventory", "Type": 0 }],
          "Select": [{ "Column": { "Expression": { "SourceRef": { "Source": "i" } }, "Property": "triplet_name" }, "Name": "inventory.triplet_name" }]
        },
        "objects": {
          "general": [{ "properties": { "orientation": { "expr": { "Literal": { "Value": "'Horizontal'" } } } } }],
          "selection": [{ "properties": { "selectAllCheckboxEnabled": { "expr": { "Literal": { "Value": "true" } } }, "singleSelect": { "expr": { "Literal": { "Value": "false" } } } } }],
          "header": [{ "properties": { "show": { "expr": { "Literal": { "Value": "true" } } }, "text": { "expr": { "Literal": { "Value": "'Triplet'" } } }, "fontColor": { "solid": { "color": "#888780" } }, "fontSize": { "expr": { "Literal": { "Value": "10D" } } } } }]
        }
      }
    },

    {
      "id": "slicer-workspace",
      "x": 240, "y": 155, "width": 200, "height": 50,
      "visual": {
        "visualType": "slicer",
        "projections": {
          "Values": [{ "queryRef": "inventory.workspace", "active": true }]
        },
        "prototypeQuery": {
          "Version": 2,
          "From": [{ "Name": "i", "Entity": "inventory", "Type": 0 }],
          "Select": [{ "Column": { "Expression": { "SourceRef": { "Source": "i" } }, "Property": "workspace" }, "Name": "inventory.workspace" }]
        },
        "objects": {
          "general": [{ "properties": { "orientation": { "expr": { "Literal": { "Value": "'Horizontal'" } } } } }],
          "selection": [{ "properties": { "selectAllCheckboxEnabled": { "expr": { "Literal": { "Value": "true" } } }, "singleSelect": { "expr": { "Literal": { "Value": "false" } } } } }],
          "header": [{ "properties": { "show": { "expr": { "Literal": { "Value": "true" } } }, "text": { "expr": { "Literal": { "Value": "'Workspace'" } } }, "fontColor": { "solid": { "color": "#888780" } }, "fontSize": { "expr": { "Literal": { "Value": "10D" } } } } }]
        }
      }
    },

    {
      "id": "slicer-object-type",
      "x": 460, "y": 155, "width": 200, "height": 50,
      "visual": {
        "visualType": "slicer",
        "projections": {
          "Values": [{ "queryRef": "inventory.object_type", "active": true }]
        },
        "prototypeQuery": {
          "Version": 2,
          "From": [{ "Name": "i", "Entity": "inventory", "Type": 0 }],
          "Select": [{ "Column": { "Expression": { "SourceRef": { "Source": "i" } }, "Property": "object_type" }, "Name": "inventory.object_type" }]
        },
        "objects": {
          "general": [{ "properties": { "orientation": { "expr": { "Literal": { "Value": "'Horizontal'" } } } } }],
          "selection": [{ "properties": { "selectAllCheckboxEnabled": { "expr": { "Literal": { "Value": "true" } } }, "singleSelect": { "expr": { "Literal": { "Value": "false" } } } } }],
          "header": [{ "properties": { "show": { "expr": { "Literal": { "Value": "true" } } }, "text": { "expr": { "Literal": { "Value": "'Object Type'" } } }, "fontColor": { "solid": { "color": "#888780" } }, "fontSize": { "expr": { "Literal": { "Value": "10D" } } } } }]
        }
      }
    },

    {
      "id": "slicer-violations-only",
      "x": 680, "y": 155, "width": 160, "height": 50,
      "visual": {
        "visualType": "slicer",
        "projections": {
          "Values": [{ "queryRef": "inventory.has_violation", "active": true }]
        },
        "prototypeQuery": {
          "Version": 2,
          "From": [{ "Name": "i", "Entity": "inventory", "Type": 0 }],
          "Select": [{ "Column": { "Expression": { "SourceRef": { "Source": "i" } }, "Property": "has_violation" }, "Name": "inventory.has_violation" }]
        },
        "objects": {
          "general": [{ "properties": { "orientation": { "expr": { "Literal": { "Value": "'Horizontal'" } } } } }],
          "selection": [{ "properties": { "singleSelect": { "expr": { "Literal": { "Value": "false" } } } } }],
          "header": [{ "properties": { "show": { "expr": { "Literal": { "Value": "true" } } }, "text": { "expr": { "Literal": { "Value": "'Violations Only'" } } }, "fontColor": { "solid": { "color": "#888780" } }, "fontSize": { "expr": { "Literal": { "Value": "10D" } } } } }]
        }
      }
    },

    {
      "id": "table-inventory",
      "x": 20, "y": 215, "width": 840, "height": 490,
      "visual": {
        "visualType": "tableEx",
        "projections": {
          "Values": [
            { "queryRef": "inventory.triplet_name", "active": true },
            { "queryRef": "inventory.workspace", "active": true },
            { "queryRef": "inventory.object_name", "active": true },
            { "queryRef": "inventory.object_type", "active": true },
            { "queryRef": "inventory.sync_state", "active": true },
            { "queryRef": "inventory.exists_in_dev", "active": true },
            { "queryRef": "inventory.exists_in_test", "active": true },
            { "queryRef": "inventory.exists_in_prod", "active": true },
            { "queryRef": "inventory.exists_in_git", "active": true },
            { "queryRef": "inventory.last_modified", "active": true },
            { "queryRef": "Measures.Violation Flag", "active": true }
          ]
        },
        "prototypeQuery": {
          "Version": 2,
          "From": [
            { "Name": "i", "Entity": "inventory", "Type": 0 },
            { "Name": "m", "Entity": "Measures", "Type": 0 }
          ],
          "Select": [
            { "Column": { "Expression": { "SourceRef": { "Source": "i" } }, "Property": "triplet_name" }, "Name": "inventory.triplet_name" },
            { "Column": { "Expression": { "SourceRef": { "Source": "i" } }, "Property": "workspace" }, "Name": "inventory.workspace" },
            { "Column": { "Expression": { "SourceRef": { "Source": "i" } }, "Property": "object_name" }, "Name": "inventory.object_name" },
            { "Column": { "Expression": { "SourceRef": { "Source": "i" } }, "Property": "object_type" }, "Name": "inventory.object_type" },
            { "Column": { "Expression": { "SourceRef": { "Source": "i" } }, "Property": "sync_state" }, "Name": "inventory.sync_state" },
            { "Column": { "Expression": { "SourceRef": { "Source": "i" } }, "Property": "exists_in_dev" }, "Name": "inventory.exists_in_dev" },
            { "Column": { "Expression": { "SourceRef": { "Source": "i" } }, "Property": "exists_in_test" }, "Name": "inventory.exists_in_test" },
            { "Column": { "Expression": { "SourceRef": { "Source": "i" } }, "Property": "exists_in_prod" }, "Name": "inventory.exists_in_prod" },
            { "Column": { "Expression": { "SourceRef": { "Source": "i" } }, "Property": "exists_in_git" }, "Name": "inventory.exists_in_git" },
            { "Column": { "Expression": { "SourceRef": { "Source": "i" } }, "Property": "last_modified" }, "Name": "inventory.last_modified" },
            { "Measure": { "Expression": { "SourceRef": { "Source": "m" } }, "Property": "Violation Flag" }, "Name": "Measures.Violation Flag" }
          ],
          "OrderBy": [
            { "Direction": 1, "Expression": { "Column": { "Expression": { "SourceRef": { "Source": "i" } }, "Property": "triplet_name" } } }
          ]
        },
        "objects": {
          "title": [{ "properties": {
            "show": { "expr": { "Literal": { "Value": "true" } } },
            "text": { "expr": { "Literal": { "Value": "'Object Inventory — all workspaces'" } } },
            "fontSize": { "expr": { "Literal": { "Value": "11D" } } },
            "fontColor": { "solid": { "color": "#888780" } }
          }}],
          "grid": [{ "properties": {
            "rowPadding": { "expr": { "Literal": { "Value": "6D" } } },
            "gridHorizontalColor": { "solid": { "color": "#E0DFD8" } },
            "outlineColor": { "solid": { "color": "#E0DFD8" } }
          }}],
          "columnHeaders": [{ "properties": {
            "fontColor": { "solid": { "color": "#888780" } },
            "fontSize": { "expr": { "Literal": { "Value": "10D" } } },
            "backColor": { "solid": { "color": "#F4F3EE" } }
          }}],
          "values": [{ "properties": {
            "fontColorPrimary": { "solid": { "color": "#1A1A2E" } },
            "backColorPrimary": { "solid": { "color": "#FFFFFF" } },
            "backColorSecondary": { "solid": { "color": "#F9F8F5" } },
            "fontSize": { "expr": { "Literal": { "Value": "11D" } } }
          }}]
        },
        "conditionalFormatting": [
          {
            "visualField": "inventory.sync_state",
            "type": "fontColor",
            "rules": [
              { "operator": "Is", "value": "Synced", "color": { "solid": { "color": "#0F6E56" } } },
              { "operator": "Is", "value": "Unsynced", "color": { "solid": { "color": "#A32D2D" } } }
            ]
          },
          {
            "visualField": "Measures.Violation Flag",
            "type": "background",
            "rules": [
              { "operator": "Is", "value": "Clean", "color": { "solid": { "color": "#E1F5EE" } } },
              { "operator": "IsNot", "value": "Clean", "color": { "solid": { "color": "#FCEBEB" } } }
            ]
          },
          {
            "visualField": "Measures.Violation Flag",
            "type": "fontColor",
            "rules": [
              { "operator": "Is", "value": "Clean", "color": { "solid": { "color": "#0F6E56" } } },
              { "operator": "IsNot", "value": "Clean", "color": { "solid": { "color": "#A32D2D" } } }
            ]
          },
          {
            "visualField": "inventory.workspace",
            "type": "background",
            "rules": [
              { "operator": "Is", "value": "Dev", "color": { "solid": { "color": "#E6F1FB" } } },
              { "operator": "Is", "value": "Test", "color": { "solid": { "color": "#FAEEDA" } } },
              { "operator": "Is", "value": "Prod", "color": { "solid": { "color": "#FCEBEB" } } }
            ]
          }
        ]
      }
    },

    {
      "id": "bar-env-coverage",
      "x": 880, "y": 215, "width": 380, "height": 300,
      "visual": {
        "visualType": "clusteredBarChart",
        "projections": {
          "Category": [{ "queryRef": "inventory.triplet_name", "active": true }],
          "Y": [
            { "queryRef": "Measures.Test Coverage Pct", "active": true },
            { "queryRef": "Measures.Prod Coverage Pct", "active": true }
          ]
        },
        "prototypeQuery": {
          "Version": 2,
          "From": [
            { "Name": "i", "Entity": "inventory", "Type": 0 },
            { "Name": "m", "Entity": "Measures", "Type": 0 }
          ],
          "Select": [
            { "Column": { "Expression": { "SourceRef": { "Source": "i" } }, "Property": "triplet_name" }, "Name": "inventory.triplet_name" },
            { "Measure": { "Expression": { "SourceRef": { "Source": "m" } }, "Property": "Test Coverage Pct" }, "Name": "Measures.Test Coverage Pct" },
            { "Measure": { "Expression": { "SourceRef": { "Source": "m" } }, "Property": "Prod Coverage Pct" }, "Name": "Measures.Prod Coverage Pct" }
          ]
        },
        "objects": {
          "title": [{ "properties": {
            "show": { "expr": { "Literal": { "Value": "true" } } },
            "text": { "expr": { "Literal": { "Value": "'Environment Coverage by Triplet (% of Dev)'" } } },
            "fontSize": { "expr": { "Literal": { "Value": "11D" } } },
            "fontColor": { "solid": { "color": "#888780" } }
          }}],
          "dataColors": [{ "properties": {
            "Test Coverage Pct": { "solid": { "color": "#1D9E75" } },
            "Prod Coverage Pct": { "solid": { "color": "#378ADD" } }
          }}],
          "legend": [{ "properties": {
            "show": { "expr": { "Literal": { "Value": "true" } } },
            "position": { "expr": { "Literal": { "Value": "'Top'" } } },
            "fontSize": { "expr": { "Literal": { "Value": "10D" } } }
          }}],
          "valueAxis": [{ "properties": {
            "start": { "expr": { "Literal": { "Value": "0D" } } },
            "end": { "expr": { "Literal": { "Value": "100D" } } },
            "labelDisplayUnits": { "expr": { "Literal": { "Value": "0D" } } }
          }}]
        }
      }
    },

    {
      "id": "matrix-object-dist",
      "x": 880, "y": 525, "width": 380, "height": 180,
      "visual": {
        "visualType": "matrix",
        "projections": {
          "Rows": [{ "queryRef": "inventory.object_type", "active": true }],
          "Columns": [{ "queryRef": "inventory.workspace", "active": true }],
          "Values": [{ "queryRef": "Measures.Object Count", "active": true }]
        },
        "prototypeQuery": {
          "Version": 2,
          "From": [
            { "Name": "i", "Entity": "inventory", "Type": 0 },
            { "Name": "m", "Entity": "Measures", "Type": 0 }
          ],
          "Select": [
            { "Column": { "Expression": { "SourceRef": { "Source": "i" } }, "Property": "object_type" }, "Name": "inventory.object_type" },
            { "Column": { "Expression": { "SourceRef": { "Source": "i" } }, "Property": "workspace" }, "Name": "inventory.workspace" },
            { "Measure": { "Expression": { "SourceRef": { "Source": "m" } }, "Property": "Object Count" }, "Name": "Measures.Object Count" }
          ]
        },
        "objects": {
          "title": [{ "properties": {
            "show": { "expr": { "Literal": { "Value": "true" } } },
            "text": { "expr": { "Literal": { "Value": "'Object Distribution by Type & Workspace'" } } },
            "fontSize": { "expr": { "Literal": { "Value": "11D" } } },
            "fontColor": { "solid": { "color": "#888780" } }
          }}],
          "subTotals": [{ "properties": {
            "rowSubtotals": { "expr": { "Literal": { "Value": "true" } } },
            "columnSubtotals": { "expr": { "Literal": { "Value": "true" } } }
          }}],
          "grid": [{ "properties": {
            "rowPadding": { "expr": { "Literal": { "Value": "5D" } } },
            "gridHorizontalColor": { "solid": { "color": "#E0DFD8" } },
            "gridVerticalColor": { "solid": { "color": "#E0DFD8" } }
          }}]
        }
      }
    }

  ]
}
