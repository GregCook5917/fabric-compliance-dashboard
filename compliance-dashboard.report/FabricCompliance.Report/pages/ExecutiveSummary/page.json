{
  "name": "ExecutiveSummary",
  "displayName": "Executive Summary",
  "ordinal": 0,
  "width": 1280,
  "height": 720,
  "background": {
    "color": { "solid": { "color": "#F4F3EE" } },
    "transparency": 0
  },
  "visualContainers": [

    {
      "id": "header-bar",
      "x": 0, "y": 0, "width": 1280, "height": 50,
      "visual": {
        "visualType": "shape",
        "projections": {},
        "prototypeQuery": {},
        "drillFilterOtherVisuals": false,
        "objects": {
          "general": [{ "properties": { "fill": { "solid": { "color": "#1A1A2E" } } } }],
          "border": [{ "properties": { "show": { "expr": { "Literal": { "Value": "false" } } } } }]
        }
      }
    },

    {
      "id": "header-title",
      "x": 20, "y": 8, "width": 400, "height": 34,
      "visual": {
        "visualType": "textbox",
        "objects": {
          "general": [{
            "properties": {
              "paragraphs": [{
                "textRuns": [{
                  "value": "Fabric Deployment Compliance",
                  "textStyle": { "fontFamily": "Segoe UI", "fontSize": "14pt", "bold": true, "color": "#FFFFFF" }
                }]
              }]
            }
          }]
        }
      }
    },

    {
      "id": "slicer-triplet",
      "x": 800, "y": 8, "width": 460, "height": 34,
      "visual": {
        "visualType": "slicer",
        "projections": {
          "Values": [{ "queryRef": "violations.triplet_name", "active": true }]
        },
        "prototypeQuery": {
          "Version": 2,
          "From": [{ "Name": "v", "Entity": "violations", "Type": 0 }],
          "Select": [{ "Column": { "Expression": { "SourceRef": { "Source": "v" } }, "Property": "triplet_name" }, "Name": "violations.triplet_name" }]
        },
        "objects": {
          "general": [{ "properties": { "orientation": { "expr": { "Literal": { "Value": "'Horizontal'" } } }, "filter": {} } }],
          "selection": [{ "properties": { "selectAllCheckboxEnabled": { "expr": { "Literal": { "Value": "true" } } }, "singleSelect": { "expr": { "Literal": { "Value": "false" } } } } }],
          "header": [{ "properties": { "show": { "expr": { "Literal": { "Value": "false" } } } } }],
          "items": [{ "properties": {
            "fontColor": { "solid": { "color": "#1A1A2E" } },
            "background": { "solid": { "color": "#EEEDFE" } }
          }}]
        }
      }
    },

    {
      "id": "kpi-compliance",
      "x": 20, "y": 60, "width": 290, "height": 90,
      "visual": {
        "visualType": "card",
        "projections": {
          "Values": [{ "queryRef": "Measures.Compliance Rate", "active": true }]
        },
        "prototypeQuery": {
          "Version": 2,
          "From": [{ "Name": "m", "Entity": "Measures", "Type": 0 }],
          "Select": [{ "Measure": { "Expression": { "SourceRef": { "Source": "m" } }, "Property": "Compliance Rate" }, "Name": "Measures.Compliance Rate" }]
        },
        "objects": {
          "labels": [{ "properties": {
            "color": { "solid": { "color": "#0F6E56" } },
            "fontSize": { "expr": { "Literal": { "Value": "28D" } } },
            "fontFamily": "Segoe UI"
          }}],
          "categoryLabels": [{ "properties": {
            "show": { "expr": { "Literal": { "Value": "true" } } },
            "color": { "solid": { "color": "#888780" } },
            "fontSize": { "expr": { "Literal": { "Value": "10D" } } }
          }}],
          "title": [{ "properties": {
            "show": { "expr": { "Literal": { "Value": "true" } } },
            "text": { "expr": { "Literal": { "Value": "'Overall Compliance'" } } },
            "fontColor": { "solid": { "color": "#888780" } },
            "fontSize": { "expr": { "Literal": { "Value": "10D" } } }
          }}]
        }
      }
    },

    {
      "id": "kpi-violations",
      "x": 330, "y": 60, "width": 290, "height": 90,
      "visual": {
        "visualType": "card",
        "projections": {
          "Values": [{ "queryRef": "Measures.Total Violations", "active": true }]
        },
        "prototypeQuery": {
          "Version": 2,
          "From": [{ "Name": "m", "Entity": "Measures", "Type": 0 }],
          "Select": [{ "Measure": { "Expression": { "SourceRef": { "Source": "m" } }, "Property": "Total Violations" }, "Name": "Measures.Total Violations" }]
        },
        "objects": {
          "labels": [{ "properties": {
            "color": { "solid": { "color": "#A32D2D" } },
            "fontSize": { "expr": { "Literal": { "Value": "28D" } } }
          }}],
          "title": [{ "properties": {
            "show": { "expr": { "Literal": { "Value": "true" } } },
            "text": { "expr": { "Literal": { "Value": "'Total Violations'" } } },
            "fontColor": { "solid": { "color": "#888780" } },
            "fontSize": { "expr": { "Literal": { "Value": "10D" } } }
          }}]
        }
      }
    },

    {
      "id": "kpi-objects",
      "x": 640, "y": 60, "width": 290, "height": 90,
      "visual": {
        "visualType": "card",
        "projections": {
          "Values": [{ "queryRef": "Measures.Total Objects", "active": true }]
        },
        "prototypeQuery": {
          "Version": 2,
          "From": [{ "Name": "m", "Entity": "Measures", "Type": 0 }],
          "Select": [{ "Measure": { "Expression": { "SourceRef": { "Source": "m" } }, "Property": "Total Objects" }, "Name": "Measures.Total Objects" }]
        },
        "objects": {
          "labels": [{ "properties": {
            "color": { "solid": { "color": "#1A1A2E" } },
            "fontSize": { "expr": { "Literal": { "Value": "28D" } } }
          }}],
          "title": [{ "properties": {
            "show": { "expr": { "Literal": { "Value": "true" } } },
            "text": { "expr": { "Literal": { "Value": "'Objects Monitored'" } } },
            "fontColor": { "solid": { "color": "#888780" } },
            "fontSize": { "expr": { "Literal": { "Value": "10D" } } }
          }}]
        }
      }
    },

    {
      "id": "kpi-critical",
      "x": 950, "y": 60, "width": 310, "height": 90,
      "visual": {
        "visualType": "card",
        "projections": {
          "Values": [{ "queryRef": "Measures.Critical Orphans", "active": true }]
        },
        "prototypeQuery": {
          "Version": 2,
          "From": [{ "Name": "m", "Entity": "Measures", "Type": 0 }],
          "Select": [{ "Measure": { "Expression": { "SourceRef": { "Source": "m" } }, "Property": "Critical Orphans" }, "Name": "Measures.Critical Orphans" }]
        },
        "objects": {
          "labels": [{ "properties": {
            "color": { "solid": { "color": "#D85A30" } },
            "fontSize": { "expr": { "Literal": { "Value": "28D" } } }
          }}],
          "title": [{ "properties": {
            "show": { "expr": { "Literal": { "Value": "true" } } },
            "text": { "expr": { "Literal": { "Value": "'Critical (Orphans)'" } } },
            "fontColor": { "solid": { "color": "#888780" } },
            "fontSize": { "expr": { "Literal": { "Value": "10D" } } }
          }}]
        }
      }
    },

    {
      "id": "bar-violations-by-type",
      "x": 20, "y": 165, "width": 590, "height": 240,
      "visual": {
        "visualType": "barChart",
        "projections": {
          "Category": [{ "queryRef": "violations.violation_type", "active": true }],
          "Y": [{ "queryRef": "Measures.Total Violations", "active": true }]
        },
        "prototypeQuery": {
          "Version": 2,
          "From": [
            { "Name": "v", "Entity": "violations", "Type": 0 },
            { "Name": "m", "Entity": "Measures", "Type": 0 }
          ],
          "Select": [
            { "Column": { "Expression": { "SourceRef": { "Source": "v" } }, "Property": "violation_type" }, "Name": "violations.violation_type" },
            { "Measure": { "Expression": { "SourceRef": { "Source": "m" } }, "Property": "Total Violations" }, "Name": "Measures.Total Violations" }
          ],
          "OrderBy": [{ "Direction": 2, "Expression": { "Measure": { "Expression": { "SourceRef": { "Source": "m" } }, "Property": "Total Violations" } } }]
        },
        "objects": {
          "title": [{ "properties": {
            "show": { "expr": { "Literal": { "Value": "true" } } },
            "text": { "expr": { "Literal": { "Value": "'Violations by Type'" } } },
            "fontSize": { "expr": { "Literal": { "Value": "11D" } } },
            "fontColor": { "solid": { "color": "#888780" } }
          }}],
          "dataPoint": [{ "properties": {
            "defaultColor": { "solid": { "color": "#E24B4A" } }
          }}],
          "dataColors": [{ "properties": {
            "UNSYNCED": { "solid": { "color": "#E24B4A" } },
            "ORPHANED_OBJECT": { "solid": { "color": "#EF9F27" } },
            "UNCOMMITTED_PROMOTION": { "solid": { "color": "#7F77DD" } }
          }}],
          "categoryAxis": [{ "properties": {
            "fontSize": { "expr": { "Literal": { "Value": "10D" } } },
            "fontColor": { "solid": { "color": "#888780" } }
          }}],
          "valueAxis": [{ "properties": {
            "show": { "expr": { "Literal": { "Value": "true" } } },
            "fontSize": { "expr": { "Literal": { "Value": "10D" } } }
          }}],
          "legend": [{ "properties": { "show": { "expr": { "Literal": { "Value": "false" } } } }]
        }
      }
    },

    {
      "id": "donut-violation-dist",
      "x": 630, "y": 165, "width": 310, "height": 240,
      "visual": {
        "visualType": "donutChart",
        "projections": {
          "Category": [{ "queryRef": "violations.violation_type", "active": true }],
          "Y": [{ "queryRef": "Measures.Total Violations", "active": true }]
        },
        "prototypeQuery": {
          "Version": 2,
          "From": [
            { "Name": "v", "Entity": "violations", "Type": 0 },
            { "Name": "m", "Entity": "Measures", "Type": 0 }
          ],
          "Select": [
            { "Column": { "Expression": { "SourceRef": { "Source": "v" } }, "Property": "violation_type" }, "Name": "violations.violation_type" },
            { "Measure": { "Expression": { "SourceRef": { "Source": "m" } }, "Property": "Total Violations" }, "Name": "Measures.Total Violations" }
          ]
        },
        "objects": {
          "title": [{ "properties": {
            "show": { "expr": { "Literal": { "Value": "true" } } },
            "text": { "expr": { "Literal": { "Value": "'Violation Distribution'" } } },
            "fontSize": { "expr": { "Literal": { "Value": "11D" } } },
            "fontColor": { "solid": { "color": "#888780" } }
          }}],
          "legend": [{ "properties": {
            "show": { "expr": { "Literal": { "Value": "true" } } },
            "position": { "expr": { "Literal": { "Value": "'Right'" } } },
            "fontSize": { "expr": { "Literal": { "Value": "10D" } } }
          }}],
          "dataColors": [{ "properties": {
            "UNSYNCED": { "solid": { "color": "#E24B4A" } },
            "ORPHANED_OBJECT": { "solid": { "color": "#EF9F27" } },
            "UNCOMMITTED_PROMOTION": { "solid": { "color": "#7F77DD" } }
          }}]
        }
      }
    },

    {
      "id": "bar-compliance-by-workspace",
      "x": 960, "y": 165, "width": 300, "height": 240,
      "visual": {
        "visualType": "barChart",
        "projections": {
          "Category": [{ "queryRef": "inventory.workspace", "active": true }],
          "Y": [{ "queryRef": "Measures.Workspace Compliance Rate", "active": true }]
        },
        "prototypeQuery": {
          "Version": 2,
          "From": [
            { "Name": "i", "Entity": "inventory", "Type": 0 },
            { "Name": "m", "Entity": "Measures", "Type": 0 }
          ],
          "Select": [
            { "Column": { "Expression": { "SourceRef": { "Source": "i" } }, "Property": "workspace" }, "Name": "inventory.workspace" },
            { "Measure": { "Expression": { "SourceRef": { "Source": "m" } }, "Property": "Workspace Compliance Rate" }, "Name": "Measures.Workspace Compliance Rate" }
          ]
        },
        "objects": {
          "title": [{ "properties": {
            "show": { "expr": { "Literal": { "Value": "true" } } },
            "text": { "expr": { "Literal": { "Value": "'Compliance by Workspace'" } } },
            "fontSize": { "expr": { "Literal": { "Value": "11D" } } },
            "fontColor": { "solid": { "color": "#888780" } }
          }}],
          "dataPoint": [{ "properties": {
            "defaultColor": { "solid": { "color": "#1D9E75" } }
          }}],
          "valueAxis": [{ "properties": {
            "start": { "expr": { "Literal": { "Value": "0D" } } },
            "end": { "expr": { "Literal": { "Value": "100D" } } }
          }}]
        }
      }
    },

    {
      "id": "matrix-heatmap",
      "x": 20, "y": 420, "width": 630, "height": 280,
      "visual": {
        "visualType": "matrix",
        "projections": {
          "Rows": [{ "queryRef": "violations.triplet_name", "active": true }],
          "Columns": [{ "queryRef": "violations.violation_type", "active": true }],
          "Values": [{ "queryRef": "Measures.Total Violations", "active": true }]
        },
        "prototypeQuery": {
          "Version": 2,
          "From": [
            { "Name": "v", "Entity": "violations", "Type": 0 },
            { "Name": "m", "Entity": "Measures", "Type": 0 }
          ],
          "Select": [
            { "Column": { "Expression": { "SourceRef": { "Source": "v" } }, "Property": "triplet_name" }, "Name": "violations.triplet_name" },
            { "Column": { "Expression": { "SourceRef": { "Source": "v" } }, "Property": "violation_type" }, "Name": "violations.violation_type" },
            { "Measure": { "Expression": { "SourceRef": { "Source": "m" } }, "Property": "Total Violations" }, "Name": "Measures.Total Violations" }
          ]
        },
        "objects": {
          "title": [{ "properties": {
            "show": { "expr": { "Literal": { "Value": "true" } } },
            "text": { "expr": { "Literal": { "Value": "'Violation Heatmap — Triplet by Type'" } } },
            "fontSize": { "expr": { "Literal": { "Value": "11D" } } },
            "fontColor": { "solid": { "color": "#888780" } }
          }}],
          "subTotals": [{ "properties": {
            "rowSubtotals": { "expr": { "Literal": { "Value": "false" } } },
            "columnSubtotals": { "expr": { "Literal": { "Value": "false" } } }
          }}],
          "grid": [{ "properties": {
            "rowPadding": { "expr": { "Literal": { "Value": "6D" } } },
            "outlineColor": { "solid": { "color": "#E0DFD8" } },
            "gridVertical": { "expr": { "Literal": { "Value": "true" } } },
            "gridVerticalColor": { "solid": { "color": "#E0DFD8" } },
            "gridHorizontal": { "expr": { "Literal": { "Value": "true" } } },
            "gridHorizontalColor": { "solid": { "color": "#E0DFD8" } }
          }}],
          "columnHeaders": [{ "properties": {
            "fontColor": { "solid": { "color": "#888780" } },
            "fontSize": { "expr": { "Literal": { "Value": "10D" } } },
            "fontFamily": "Segoe UI"
          }}],
          "rowHeaders": [{ "properties": {
            "fontColor": { "solid": { "color": "#1A1A2E" } },
            "fontSize": { "expr": { "Literal": { "Value": "11D" } } }
          }}],
          "values": [{ "properties": {
            "fontColorPrimary": { "solid": { "color": "#1A1A2E" } },
            "fontSize": { "expr": { "Literal": { "Value": "11D" } } }
          }}]
        },
        "conditionalFormatting": [
          {
            "visualField": "Measures.Total Violations",
            "type": "background",
            "conditions": [
              { "operator": "Is", "value": 0, "color": { "solid": { "color": "#E1F5EE" } } },
              { "operator": "Between", "value": 1, "value2": 3, "color": { "solid": { "color": "#FAEEDA" } } },
              { "operator": "GreaterThanOrEqual", "value": 4, "color": { "solid": { "color": "#FAECE7" } } }
            ]
          },
          {
            "visualField": "Measures.Total Violations",
            "type": "fontColor",
            "conditions": [
              { "operator": "Is", "value": 0, "color": { "solid": { "color": "#0F6E56" } } },
              { "operator": "Between", "value": 1, "value2": 3, "color": { "solid": { "color": "#854F0B" } } },
              { "operator": "GreaterThanOrEqual", "value": 4, "color": { "solid": { "color": "#A32D2D" } } }
            ]
          }
        ]
      }
    },

    {
      "id": "table-triplet-health",
      "x": 670, "y": 420, "width": 590, "height": 280,
      "visual": {
        "visualType": "tableEx",
        "projections": {
          "Values": [
            { "queryRef": "violations.triplet_name", "active": true },
            { "queryRef": "Measures.Total Violations", "active": true },
            { "queryRef": "Measures.Top Violation Type", "active": true },
            { "queryRef": "Measures.Compliance Rate", "active": true }
          ]
        },
        "prototypeQuery": {
          "Version": 2,
          "From": [
            { "Name": "v", "Entity": "violations", "Type": 0 },
            { "Name": "m", "Entity": "Measures", "Type": 0 }
          ],
          "Select": [
            { "Column": { "Expression": { "SourceRef": { "Source": "v" } }, "Property": "triplet_name" }, "Name": "violations.triplet_name" },
            { "Measure": { "Expression": { "SourceRef": { "Source": "m" } }, "Property": "Total Violations" }, "Name": "Measures.Total Violations" },
            { "Measure": { "Expression": { "SourceRef": { "Source": "m" } }, "Property": "Top Violation Type" }, "Name": "Measures.Top Violation Type" },
            { "Measure": { "Expression": { "SourceRef": { "Source": "m" } }, "Property": "Compliance Rate" }, "Name": "Measures.Compliance Rate" }
          ],
          "OrderBy": [{ "Direction": 2, "Expression": { "Measure": { "Expression": { "SourceRef": { "Source": "m" } }, "Property": "Total Violations" } } }]
        },
        "objects": {
          "title": [{ "properties": {
            "show": { "expr": { "Literal": { "Value": "true" } } },
            "text": { "expr": { "Literal": { "Value": "'Triplet Health at a Glance'" } } },
            "fontSize": { "expr": { "Literal": { "Value": "11D" } } },
            "fontColor": { "solid": { "color": "#888780" } }
          }}],
          "grid": [{ "properties": {
            "rowPadding": { "expr": { "Literal": { "Value": "8D" } } },
            "outlineColor": { "solid": { "color": "#E0DFD8" } },
            "gridHorizontalColor": { "solid": { "color": "#E0DFD8" } }
          }}],
          "columnHeaders": [{ "properties": {
            "fontColor": { "solid": { "color": "#888780" } },
            "fontSize": { "expr": { "Literal": { "Value": "10D" } } },
            "backColor": { "solid": { "color": "#F4F3EE" } }
          }}],
          "values": [{ "properties": {
            "fontColorPrimary": { "solid": { "color": "#1A1A2E" } },
            "fontSize": { "expr": { "Literal": { "Value": "11D" } } }
          }}]
        },
        "conditionalFormatting": [
          {
            "visualField": "Measures.Compliance Rate",
            "type": "background",
            "gradient": {
              "minColor": { "solid": { "color": "#FCEBEB" } },
              "midColor": { "solid": { "color": "#FAEEDA" } },
              "maxColor": { "solid": { "color": "#E1F5EE" } },
              "minValue": 0,
              "midValue": 75,
              "maxValue": 100
            }
          }
        ]
      }
    }

  ]
}
